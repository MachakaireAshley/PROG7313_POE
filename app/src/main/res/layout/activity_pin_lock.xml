<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/custom_blue"
    >

    <!-- App Logo/Icon -->
    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="200dp"
        android:layout_height="193dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="App Logo"
        android:src="@drawable/logo" />



    <!-- PIN Title -->
    <TextView
        android:id="@+id/pinTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textSize="18sp"
        android:textColor="#333333"
        android:layout_marginBottom="12dp" />

    <!-- PIN Dots Container -->
    <LinearLayout
        android:id="@+id/pinDotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="18dp">

        <!-- 4 PIN Dots -->
        <View
            android:id="@+id/pinDot1"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/pin_dot_empty" />

        <View
            android:id="@+id/pinDot2"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/pin_dot_empty" />

        <View
            android:id="@+id/pinDot3"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/pin_dot_empty" />

        <View
            android:id="@+id/pinDot4"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/pin_dot_empty" />

    </LinearLayout>

    <!-- Error Message -->
    <TextView
        android:id="@+id/errorMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#F44336"
        android:layout_marginBottom="32dp"
        android:visibility="gone" />

    <!-- PIN Pad -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rowCount="4"
        android:columnCount="3"
        android:layout_marginBottom="12dp">

        <!-- Row 1 -->
        <Button
            android:id="@+id/btn1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="1"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="2"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="3"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <!-- Row 2 -->
        <Button
            android:id="@+id/btn4"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="4"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="5"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="6"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <!-- Row 3 -->
        <Button
            android:id="@+id/btn7"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="7"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="8"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="9"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <!-- Row 4 -->

        <Button
            android:id="@+id/btnBiometric"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text=" "
            android:textSize="28sp"
            android:textColor="#6200EE"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle"
             />
        <Button
            android:id="@+id/btn0"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="0"
            android:textSize="28sp"
            android:textColor="#333333"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="⌫"
            android:textSize="28sp"
            android:textColor="#666666"
            android:background="@drawable/pin_button"
            android:layout_margin="8dp"
            style="?attr/borderlessButtonStyle" />



    </GridLayout>

    <!-- Forgot PIN Link -->
    <TextView
        android:id="@+id/forgotPinText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot PIN?"
        android:textSize="14sp"
        android:textColor="#333333"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <!-- Attempts Remaining (Shows after failed attempts) -->
    <TextView
        android:id="@+id/attemptsRemaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/expense_red"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <!--This 'item' xml is the format for each recurring item-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!--The text should change to the info of recurring item that the user sets -->
                <TextView
                    android:id="@+id/recurring_itemTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Netflix Subscription"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/recurring_item_categoryName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entertainment"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/recurring_item_frequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:drawableStart="@drawable/ic_repeat"
                        android:drawablePadding="4dp" />

                    <TextView
                        android:id="@+id/recurring_item_nextDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next: Mar 15"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:layout_marginStart="12dp"
                        android:drawableStart="@drawable/ic_home_calendar"
                        android:drawablePadding="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Amount  -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/recurring_item_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$15.99"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#6200EE" />

            </LinearLayout>

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:padding="8dp"
            android:background="#FAFAFA"
            android:id="@+id/recurring_item_actionButtons">

            <Button
                android:id="@+id/recurring_item_detailButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/custom_blue"
                android:text="Detail"
                android:textColor="#FAFAFA"
                android:textSize="12sp" />

            <Button
                android:id="@+id/recurring_item_deleteButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="#E53935"
                android:text="Delete"
                android:textColor="#FAFAFA"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
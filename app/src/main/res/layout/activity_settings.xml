<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/custom_blue">

    <!-- Sticky Title Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="4dp"
        app:titleTextColor="@color/custom_blue"
        app:title="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="start">

            <ImageView
                android:id="@+id/logoIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_logo"
                android:contentDescription="App Logo" />


        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView">



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <!-- Settings Items -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/white">

                    <!-- Recurring Items -->
                    <LinearLayout
                        android:id="@+id/recurringItemsSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_recurring"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recurring Items"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <!--go to activity_recurring_items.xml-->
                        <ImageButton
                            android:id="@+id/setting_RecurringItemsButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Recurring Items"/>


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Budgets -->
                    <LinearLayout
                        android:id="@+id/budgetsSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_budget"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Budgets"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <ImageButton
                            android:id="@+id/setting_BudgetsButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text" />


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Categories -->
                    <LinearLayout
                        android:id="@+id/categoriesSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_categories"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Categories"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <!--go to activity_category.xml-->
                        <ImageButton
                            android:id="@+id/setting_CategoriesButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Categories"/>


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Members -->
                    <LinearLayout
                        android:id="@+id/membersSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_members"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Members"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <!--go to activity_member.xml-->
                        <ImageButton
                            android:id="@+id/setting_MembersButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Members"/>


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Theme -->
                    <LinearLayout
                        android:id="@+id/themeSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_setting_theme"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Theme"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <ImageButton
                            android:id="@+id/setting_ThemeButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Theme"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Pin Lock -->
                    <LinearLayout
                        android:id="@+id/pinLockSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_pin_lock"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pin Lock"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <!--if it do have pin ,go to activity_pin_lock and after enter right pin go to dialog_setup_pin.xml-->
                        <!--if it do not have pin yet,go to dialog_setup_pin.xml-->
                        <ImageButton
                            android:id="@+id/setting_PinLockButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Pin Lock"/>


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginStart="56dp" />

                    <!-- Export CSV -->
                    <LinearLayout
                        android:id="@+id/exportCsvSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_setting_export"
                            app:tint="@color/custom_blue" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Export CSV"
                            android:textSize="16sp"
                            android:textColor="@color/primary_text"
                            android:layout_marginStart="16dp" />

                        <ImageButton
                            android:id="@+id/setting_ExportButton"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_setting_rightarrow"
                            app:tint="@color/secondary_text"
                            android:contentDescription="Export CSV"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Version Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0"
                android:textSize="12sp"
                android:textColor="@color/light_text"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/custom_blue"
        app:itemTextColor="@color/custom_blue"
        app:itemBackground="@color/white"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
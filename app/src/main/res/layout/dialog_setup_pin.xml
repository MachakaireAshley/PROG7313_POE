<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/custom_blue">
<!--using in setting page, for set up the pin number-->

    <!--Toolbar for goBack button-->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/pinSetUpToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/custom_blue"
        app:title=""
        app:contentInsetStartWithNavigation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/pinSetUpBackButton"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Navigate back"
                android:padding="24dp"
                android:src="@drawable/ic_back"
                app:tint="#000000" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Scrollable content area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="32dp">

            <!-- PIN Title -->
            <TextView
                android:id="@+id/pinTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set up PIN"
                android:textSize="36sp"
                android:textColor="#333333"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="30dp" />

            <!-- PIN Dots Container -->
            <LinearLayout
                android:id="@+id/pinDotsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="18dp">

                <!-- 4 PIN Dots (change to pin_dot_filled when user enter the number) -->
                <View
                    android:id="@+id/pinDot1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/pin_dot_empty" />

                <View
                    android:id="@+id/pinDot2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/pin_dot_empty" />

                <View
                    android:id="@+id/pinDot3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/pin_dot_empty" />

                <View
                    android:id="@+id/pinDot4"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="18dp"
                    android:background="@drawable/pin_dot_empty" />

            </LinearLayout>

            <!-- Error Message (only visible when it need)-->
            <TextView
                android:id="@+id/errorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#F44336"
                android:layout_marginBottom="32dp"
                android:visibility="gone" />

            <!-- PIN Pad -->
            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:rowCount="4"
                android:columnCount="3"
                android:layout_marginBottom="12dp">

                <!-- Row 1 -->
                <Button
                    android:id="@+id/btn1"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="1"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn2"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="2"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn3"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="3"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <!-- Row 2 -->
                <Button
                    android:id="@+id/btn4"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="4"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn5"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="5"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn6"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="6"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <!-- Row 3 -->
                <Button
                    android:id="@+id/btn7"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="7"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn8"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="8"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn9"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="9"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <!-- Row 4 -->
                <Button
                    android:id="@+id/btnBiometric"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text=""
                    android:textSize="28sp"
                    android:textColor="#6200EE"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn0"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="0"
                    android:textSize="28sp"
                    android:textColor="#333333"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="⌫"
                    android:textSize="28sp"
                    android:textColor="#666666"
                    android:background="@drawable/pin_button"
                    android:layout_margin="8dp"
                    style="?attr/borderlessButtonStyle" />

            </GridLayout>

            <!-- Attempts Remaining (Shows after failed attempts) -->
            <TextView
                android:id="@+id/attemptsRemaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/expense_red"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
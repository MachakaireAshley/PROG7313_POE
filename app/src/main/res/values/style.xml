<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PocketProtector" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/custom_blue</item>
        <item name="colorPrimaryVariant">@color/custom_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/custom_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="CalendarDateText">
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CalendarWeekDayText">
        <item name="android:textColor">@color/custom_blue</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavigationStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">12sp</item>
        <item name="itemTextAppearanceActive">@style/BottomNavigationTextActive</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavigationTextInactive</item>
    </style>

    <style name="BottomNavigationTextActive">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/custom_blue</item>
    </style>

    <style name="BottomNavigationTextInactive">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/custom_blue</item>
        <item name="android:alpha">0.7</item>
    </style>

    <style name="PinButtonStyle" parent="Widget.Material3.Button">
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:background">@drawable/pin_button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>